SPRING_PROFILES_ACTIVE=prod
SPRING_DATASOURCE_URL=jdbc:postgresql://your-rds-endpoint.ap-northeast-1.rds.amazonaws.com:5432/minigamehub
SPRING_DATASOURCE_USERNAME=minigamehub
SPRING_DATASOURCE_PASSWORD=replace-with-rds-password
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRATION_MINUTES=1440
CORS_ALLOWED_ORIGIN=https://your-amplify-domain.amplifyapp.com
HIBERNATE_DDL_AUTO=update
PORT=5000
